{
  "expo": {
    "name": "Basketball Clipper",
    "slug": "basketball-clipper",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "basketball-clipper",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galer\u00eda para seleccionar v\u00eddeos de partidos.",
        "NSCameraUsageDescription": "Acceso a la c\u00e1mara para grabar partidos directamente."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ]
  }
}
