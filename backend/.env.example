# Application
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Database
DATABASE_URL=postgresql+asyncpg://basketball:basketball@localhost:5432/basketball_clipper

# Redis
REDIS_URL=redis://localhost:6379/0

# S3-compatible storage
# En dev usamos MinIO: endpoint interno = http://minio:9000,
# URL pública que firma para el navegador = http://localhost:9000.
# En producción (AWS S3) dejar ambas variables vacías o apuntando al
# endpoint regional de AWS; boto3 decide solo.
S3_ENDPOINT_URL=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=basketball-clipper-videos

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Detector tuning ──────────────────────────────────────────────────
# Ver backend/models/README.md para cambiar a un modelo finetuneado.
DETECTOR_YOLO_MODEL=yolov8s.pt
DETECTOR_IMGSZ=1920
DETECTOR_BALL_CONF=0.15
DETECTOR_BALL_MEMORY_FRAMES=10
DETECTOR_PLAYER_HEIGHT_MIN_RATIO=0.55
DETECTOR_PLAYER_HEIGHT_MAX_RATIO=1.70
